# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (match at any depth — `/node_modules` only matched the repo
# root and let nested trees like `Claude Docs/deck/node_modules/**` leak in).
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# supabase
supabase/.temp
supabase/.branches
backups/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code session state (worktrees, plans, memory, settings). Personal
# per-machine; never belongs in the repo.
.claude/

# Scratch / throwaway files
.tmp/
.tmp-*

# Local admin/dev one-off scripts (not part of the app build)
/approve.ts
/set-supplier-state.ts
/update-supplier.ts

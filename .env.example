# Public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
APP_URL=http://localhost:3000

# Server-only
SUPABASE_SERVICE_ROLE_KEY=replace-me
GOOGLE_MAPS_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@sevent.local
# HMAC secret for the middleware → page access-decision header. Any 32+ char
# random string. When unset, the per-request access-cache optimization in
# src/proxy.ts + src/lib/auth/access.ts is skipped (slower but still correct).
SEVENT_ACCESS_SIGNING_SECRET=

# Postgres (used by docker-compose)
POSTGRES_PASSWORD=sevent-dev-password
POSTGRES_DB=sevent
POSTGRES_USER=sevent

# Public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
APP_URL=http://localhost:3000

# Server-only
SUPABASE_SERVICE_ROLE_KEY=replace-me
GOOGLE_MAPS_API_KEY=

# Resend transactional email. Apex seventsa.com is verified in Resend; the
# default from-address ("Sevent <notifications@seventsa.com>") is set in
# src/lib/notifications/email.ts and only needs an env override if you point
# sending at a different verified domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@seventsa.com
# Dev safety net: when set, every sendEmail() rewrites `to:` to this address.
# Set this to your own inbox when running locally with a prod-grade key so you
# can't accidentally email real pilot users while testing.
RESEND_DEV_REDIRECT_TO=

# Supabase Auth uses Resend for ALL auth emails (signup, password reset, etc.)
# SMTP user is literally "resend"; the password is the Resend API key.
RESEND_SMTP_PASS=
SUPABASE_AUTH_SMTP_ADMIN_EMAIL=notifications@seventsa.com

# Supabase URLs — substituted into supabase/config.toml at `supabase start`.
# Dev defaults below; production sets:
#   SUPABASE_EXTERNAL_URL=https://api.seventsa.com
#   SUPABASE_SITE_URL=https://www.seventsa.com
# Plus production must flip [auth.email.smtp].enabled = true in config.toml
# (boolean env() substitution isn't supported by this CLI version).
SUPABASE_EXTERNAL_URL=http://127.0.0.1:54321
SUPABASE_SITE_URL=http://localhost:3000

# HMAC secret for the middleware → page access-decision header. Any 32+ char
# random string. When unset, the per-request access-cache optimization in
# src/proxy.ts + src/lib/auth/access.ts is skipped (slower but still correct).
SEVENT_ACCESS_SIGNING_SECRET=

# Postgres (used by docker-compose)
POSTGRES_PASSWORD=sevent-dev-password
POSTGRES_DB=sevent
POSTGRES_USER=sevent
